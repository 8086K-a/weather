<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="60dp">

        <!-- 头部主信息区 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:id="@+id/layoutCitySelector">

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                android:text="柳州市"
                android:textColor="#333333"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="▼"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="5月20日 星期一"
            android:textColor="#888888"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⛅"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/tvTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:includeFontPadding="false"
                android:text="28°"
                android:textColor="#333333"
                android:textSize="88sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvConditionSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="多云转晴  |  最高 30°  最低 22°"
            android:textColor="#555555"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvFeelsLike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="体感温度 30°"
            android:textColor="#888888"
            android:textSize="14sp" />

        <!-- 24小时预报卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/rounded_bg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="24小时预报"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 时间段 1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="28dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlotNow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="现在" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="⛅" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 时间段 2 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="28dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlot2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14:00" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="☀️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 时间段 3 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="28dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlot3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16:00" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="☀️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="29°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 时间段 4 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="28dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlot4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:00" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="⛅" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="27°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 时间段 5 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="28dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlot5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20:00" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="☁️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                    
                    <!-- 时间段 6 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvHourSlot6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22:00" android:textColor="#888888" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="8dp" android:text="☁️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- 未来几天预报卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/rounded_bg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="未来预报"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Day 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                <TextView android:id="@+id/tvFutureDay1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="今天" android:textColor="#333333" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureIcon1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⛅" android:textSize="20sp" android:layout_marginEnd="16dp"/>
                <TextView android:id="@+id/tvFutureWeather1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="多云" android:textColor="#555555" android:textSize="14sp" />
                <TextView android:id="@+id/tvFutureLow1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22°" android:textColor="#888888" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureHigh1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="30°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="4dp"/>

            <!-- Day 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                <TextView android:id="@+id/tvFutureDay2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="明天" android:textColor="#555555" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureIcon2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌧️" android:textSize="20sp" android:layout_marginEnd="16dp"/>
                <TextView android:id="@+id/tvFutureWeather2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="小雨" android:textColor="#555555" android:textSize="14sp" />
                <TextView android:id="@+id/tvFutureLow2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="23°" android:textColor="#888888" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureHigh2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="28°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="4dp"/>

            <!-- Day 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                <TextView android:id="@+id/tvFutureDay3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="周三" android:textColor="#555555" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureIcon3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌧️" android:textSize="20sp" android:layout_marginEnd="16dp"/>
                <TextView android:id="@+id/tvFutureWeather3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="中雨" android:textColor="#555555" android:textSize="14sp" />
                <TextView android:id="@+id/tvFutureLow3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24°" android:textColor="#888888" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureHigh3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="26°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="4dp"/>

            <!-- Day 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                <TextView android:id="@+id/tvFutureDay4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="周四" android:textColor="#555555" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureIcon4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☁️" android:textSize="20sp" android:layout_marginEnd="16dp"/>
                <TextView android:id="@+id/tvFutureWeather4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="阴" android:textColor="#555555" android:textSize="14sp" />
                <TextView android:id="@+id/tvFutureLow4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22°" android:textColor="#888888" android:textSize="16sp" />
                <TextView android:id="@+id/tvFutureHigh4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="29°" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- 详细数据卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/rounded_bg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="详细信息"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💧 湿度" android:textColor="#888888" android:textSize="13sp" />
                    <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="65%" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍃 风速" android:textColor="#888888" android:textSize="13sp" />
                    <TextView android:id="@+id/tvWind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="东南风 3级" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAiFloat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="30dp"
        android:contentDescription="AI天气建议"
        android:elevation="10dp"
        app:backgroundTint="#0A84FF"
        app:fabSize="normal"
        app:maxImageSize="20dp"
        app:rippleColor="#400A84FF"
        app:srcCompat="@android:drawable/ic_dialog_info"
        app:tint="#FFFFFF" />

    <LinearLayout
        android:id="@+id/aiPanel"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/ai_panel_bg"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI 出行助手"
                android:textColor="#1C2B3A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnCloseAi"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="关闭AI助手"
                android:padding="2dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#4A5C6D" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:background="@drawable/ai_chat_bg"
            android:padding="12dp"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvAiChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="你好，我可以根据今天天气给你出行和穿衣建议。"
                android:textColor="#253545"
                android:textSize="14sp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etAiInput"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/ai_input_bg"
                android:hint="例如：我现在出门跑步合适吗？"
                android:textColorHint="#7F91A3"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="true"
                android:textColor="#1F2E3C"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSendAi"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/ai_send_button_bg"
                android:text="发送"
                android:textColor="#FFFFFF"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnStopAi"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/ai_stop_button_bg"
                android:text="停止"
                android:textAllCaps="false"
                android:textColor="#0A84FF"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
